#!/usr/bin/env bash
set -euo pipefail

remote="${GIT_AUTOPUSH_REMOTE:-origin}"
branch="${GIT_AUTOPUSH_BRANCH:-$(git branch --show-current)}"

if ! git remote get-url "$remote" >/dev/null 2>&1; then
  echo "Autopush skipped: remote '$remote' is not configured."
  exit 0
fi

if [ -z "$branch" ]; then
  echo "Autopush skipped: could not determine current branch."
  exit 0
fi

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  git push
else
  git push -u "$remote" "$branch"
fi
